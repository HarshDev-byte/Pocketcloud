[Unit]
Description=Pocket Cloud Drive USB Storage Mount
Documentation=https://github.com/pocketcloud/pocketcloud
Before=pocketcloud-backend.service

[Mount]
What=/dev/disk/by-label/PocketCloud
Where=/mnt/pocketcloud
Type=ext4
Options=defaults,noatime,nofail,x-systemd.device-timeout=10

[Install]
WantedBy=multi-user.target