# PocketCloud Backend Configuration

# Server Configuration
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database Configuration
DATABASE_PATH=/mnt/pocketcloud/data/storage.db
DATABASE_BACKUP_PATH=/mnt/pocketcloud/backups

# Storage Configuration
STORAGE_PATH=/mnt/pocketcloud/files
UPLOAD_PATH=/mnt/pocketcloud/uploads
TRASH_PATH=/mnt/pocketcloud/trash
CACHE_PATH=/mnt/pocketcloud/cache

# Authentication & Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-this

# Network Configuration
WIFI_INTERFACE=wlan0
ETHERNET_INTERFACE=eth0
HOTSPOT_SSID=PocketCloud
HOTSPOT_PASSWORD=pocketcloud123
HOTSPOT_IP=192.168.4.1
HOTSPOT_SUBNET=192.168.4.0/24

# Media Processing
FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
THUMBNAIL_QUALITY=80
VIDEO_TRANSCODE_PRESET=fast
ENABLE_HARDWARE_ACCELERATION=true

# File Upload Limits
MAX_FILE_SIZE=10737418240
MAX_FILES_PER_UPLOAD=100
ALLOWED_MIME_TYPES=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000
UPLOAD_RATE_LIMIT_MAX=10

# WebSocket Configuration
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_CONNECTIONS=50

# System Monitoring
ENABLE_SYSTEM_MONITORING=true
MONITORING_INTERVAL=5000
LOG_LEVEL=info
LOG_FILE=/var/log/pocketcloud/app.log

# Admin Configuration
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
SETUP_MODE=false

# Network Discovery
MDNS_SERVICE_NAME=pocketcloud
MDNS_SERVICE_TYPE=_http._tcp
ENABLE_CAPTIVE_PORTAL=true

# Backup & Sync
AUTO_BACKUP_ENABLED=true
BACKUP_INTERVAL_HOURS=24
SYNC_CONFLICT_RESOLUTION=timestamp

# Performance Tuning
ENABLE_COMPRESSION=true
COMPRESSION_LEVEL=6
ENABLE_CACHING=true
CACHE_TTL=3600

# Development
DEBUG=false
ENABLE_CORS=true
CORS_ORIGIN=*