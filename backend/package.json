{
  "name": "pocketcloud-backend",
  "version": "1.0.0",
  "description": "PocketCloud Drive backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node --max-old-space-size=512 dist/index.js",
    "migrate": "ts-node src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run src/tests/unit",
    "test:integration": "vitest run src/tests/integration"
  },
  "dependencies": {
    "archiver": "7.0.1",
    "bcryptjs": "2.4.3",
    "better-sqlite3": "9.4.3",
    "compression": "1.7.4",
    "cookie": "0.6.0",
    "cookie-parser": "1.4.6",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.18.3",
    "express-rate-limit": "7.2.0",
    "file-type": "^16.5.4",
    "helmet": "7.1.0",
    "jsonwebtoken": "9.0.2",
    "lru-cache": "^11.2.7",
    "multer": "1.4.5-lts.1",
    "node-cron": "3.0.3",
    "otpauth": "^9.5.0",
    "qrcode": "^1.5.4",
    "sharp": "0.33.3",
    "uuid": "9.0.0",
    "ws": "8.16.0"
  },
  "devDependencies": {
    "@types/archiver": "6.0.2",
    "@types/bcryptjs": "2.4.6",
    "@types/better-sqlite3": "7.6.9",
    "@types/compression": "1.7.5",
    "@types/cookie": "0.6.0",
    "@types/cookie-parser": "1.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "9.0.6",
    "@types/multer": "1.4.11",
    "@types/node": "20.11.30",
    "@types/node-cron": "3.0.11",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/tmp": "^0.2.6",
    "@types/uuid": "9.0.8",
    "@types/ws": "8.5.10",
    "@vitest/coverage-v8": "^4.1.0",
    "supertest": "^7.2.2",
    "tmp": "^0.2.5",
    "ts-node": "10.9.2",
    "ts-node-dev": "2.0.0",
    "typescript": "5.4.3",
    "vitest": "^4.1.0"
  }
}
