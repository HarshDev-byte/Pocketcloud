# Server
PORT=3000
NODE_ENV=development

# Storage (USB drive)
STORAGE_PATH=/mnt/pocketcloud/files
UPLOAD_TEMP_DIR=/mnt/pocketcloud/temp
THUMBNAIL_DIR=/mnt/pocketcloud/thumbnails
DB_PATH=/mnt/pocketcloud/db/pocketcloud.db
LOG_DIR=/mnt/pocketcloud/logs

# Auth
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
SESSION_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
COOKIE_MAX_AGE_DAYS=7

# Limits
MAX_FILE_SIZE_BYTES=53687091200
CHUNK_SIZE_BYTES=5242880
MAX_CONCURRENT_UPLOADS=3

# Network
PI_IP=192.168.4.1
APP_VERSION=1.0.0