{
  "name": "pocketcloud-mac",
  "version": "1.0.0",
  "description": "PocketCloud Drive - macOS Menu Bar Application",
  "main": "dist/src/main.js",
  "author": "PocketCloud Team",
  "license": "MIT",
  "homepage": "https://github.com/pocketcloud/pocketcloud-mac",
  "repository": {
    "type": "git",
    "url": "https://github.com/pocketcloud/pocketcloud-mac.git"
  },
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"npm run start:electron\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc --project tsconfig.json",
    "build:renderer": "webpack --mode production",
    "build:watch": "tsc --project tsconfig.json --watch",
    "start:electron": "wait-on dist/main.js && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "clean": "rimraf dist build",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "jest"
  },
  "build": {
    "appId": "com.pocketcloud.mac",
    "productName": "PocketCloud Drive",
    "copyright": "Copyright © 2024 PocketCloud Team",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/**/*.{md,txt}",
      "!node_modules/**/test/**/*"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/app-icon.icns",
      "minimumSystemVersion": "12.0.0",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "PocketCloud Drive",
      "icon": "assets/app-icon.icns",
      "background": "assets/dmg-background.png",
      "contents": [
        {
          "x": 130,
          "y": 220,
          "type": "file"
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ],
      "window": {
        "width": 540,
        "height": 380
      }
    },
    "publish": {
      "provider": "github",
      "owner": "pocketcloud",
      "repo": "pocketcloud-mac"
    }
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-notifier": "^8.0.5",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "concurrently": "^8.2.2",
    "css-loader": "^6.8.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.9.1",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "style-loader": "^3.3.3",
    "ts-loader": "^9.5.1",
    "typescript": "^5.3.3",
    "wait-on": "^7.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@electron/remote": "^2.1.2",
    "axios": "^1.6.2",
    "chokidar": "^3.5.3",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.7",
    "form-data": "^4.0.0",
    "node-notifier": "^10.0.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
