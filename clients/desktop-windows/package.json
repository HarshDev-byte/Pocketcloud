{
  "name": "pocketcloud-windows",
  "version": "1.0.0",
  "description": "PocketCloud Drive Windows System Tray Application",
  "main": "dist/main.js",
  "author": "PocketCloud Team",
  "license": "MIT",
  "homepage": "https://pocketcloud.local",
  "scripts": {
    "dev": "concurrently \"npm run build:watch\" \"npm run electron:dev\"",
    "build": "npm run build:main && npm run build:renderer",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "webpack --mode production",
    "build:watch": "concurrently \"npm run build:main -- --watch\" \"webpack --mode development --watch\"",
    "electron:dev": "wait-on dist/main.js && electron .",
    "electron:pack": "electron-builder --dir",
    "electron:dist": "electron-builder",
    "clean": "rimraf dist build",
    "test": "jest",
    "lint": "eslint src --ext .ts,.tsx",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.pocketcloud.windows",
    "productName": "PocketCloud Drive",
    "copyright": "Copyright © 2024 PocketCloud Team",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "assets/**/*",
      "node_modules/**/*",
      "!node_modules/*/{CHANGELOG.md,README.md,README,readme.md,readme}",
      "!node_modules/*/{test,__tests__,tests,powered-test,example,examples}",
      "!node_modules/*.d.ts",
      "!node_modules/.bin",
      "!**/*.{iml,o,hprof,orig,pyc,pyo,rbc,swp,csproj,sln,xproj}",
      "!.editorconfig",
      "!**/._*",
      "!**/{.DS_Store,.git,.hg,.svn,CVS,RCS,SCCS,.gitignore,.gitattributes}",
      "!**/{__pycache__,thumbs.db,.flowconfig,.idea,.vs,.nyc_output}",
      "!**/{appveyor.yml,.travis.yml,circle.yml}",
      "!**/{npm-debug.log,yarn.lock,.yarn-integrity,.yarn-metadata.json}"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "PocketCloud Team",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": "always",
      "createStartMenuShortcut": true,
      "shortcutName": "PocketCloud Drive",
      "include": "installer/installer.nsh",
      "script": "installer/installer.nsi"
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "pocketcloud",
      "repo": "pocketcloud-windows"
    }
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "node-notifier": "^10.0.1",
    "chokidar": "^3.5.3",
    "axios": "^1.6.2",
    "electron-updater": "^6.1.7",
    "electron-log": "^5.0.1",
    "mime-types": "^2.1.35",
    "form-data": "^4.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "30.0.0",
    "electron-builder": "^24.9.1",
    "typescript": "^5.3.3",
    "@types/node": "^20.10.5",
    "@types/ws": "^8.5.10",
    "@types/mime-types": "^2.1.4",
    "@types/react": "^18.2.45",
    "@types/react-dom": "^18.2.18",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "ts-loader": "^9.5.1",
    "html-webpack-plugin": "^5.6.0",
    "css-loader": "^6.8.1",
    "style-loader": "^3.3.3",
    "concurrently": "^8.2.2",
    "wait-on": "^7.2.0",
    "rimraf": "^5.0.5",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}