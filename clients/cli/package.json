{
  "name": "pocketcloud-cli",
  "version": "1.0.0",
  "description": "PocketCloud Drive CLI - Universal Linux client",
  "main": "dist/index.js",
  "bin": {
    "pcd": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "build:binary": "npm run build && pkg dist/index.js --targets node18-linux-x64,node18-linux-arm64 --output build/pcd",
    "dev": "ts-node src/index.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts"
  },
  "keywords": ["pocketcloud", "cli", "file-sync", "webdav", "linux"],
  "author": "PocketCloud Team",
  "license": "MIT",
  "dependencies": {
    "commander": "^11.1.0",
    "node-fetch": "^3.3.2",
    "form-data": "^4.0.0",
    "mime-types": "^2.1.35",
    "chalk": "^5.3.0",
    "ora": "^7.0.1",
    "inquirer": "^9.2.12",
    "progress": "^2.0.3",
    "fs-extra": "^11.2.0",
    "chokidar": "^3.5.3",
    "multicast-dns": "^7.2.5",
    "ip": "^1.1.8"
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.10.5",
    "@types/mime-types": "^2.1.4",
    "@types/progress": "^2.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/inquirer": "^9.0.7",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.8",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "pkg": "^5.8.1"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [],
    "targets": [
      "node18-linux-x64",
      "node18-linux-arm64"
    ],
    "outputPath": "build"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}